def _stars(r: dict) -> str:
    s  = 3 if abs(r["ou_z"]) >= 2.5 else (2 if abs(r["ou_z"]) >= 2.0 else 1)
    s += (2 if r["regime"] == "Sideways"
          else 2 if r["signal"] == "LONG"  and r["regime"] == "Bull"
          else 2 if r["signal"] == "SHORT" and r["regime"] == "Bear"
          else 0)
    s += 2 if abs(r["kf_z"]) > 1.0 else (1 if abs(r["kf_z"]) > 0.5 else 0)
    s += 2 if r["rr"] >= 2.5 else (1 if r["rr"] >= 1.5 else 0)
    if r["adf_p"] < 0.01: s += 1
    return ["⭐","⭐⭐","⭐⭐","⭐⭐⭐","⭐⭐⭐⭐","⭐⭐⭐⭐⭐"][min(s // 2, 5)]

def _confidence(r: dict) -> str:
    score  = 2 if abs(r["ou_z"]) >= 2.5 else (1 if abs(r["ou_z"]) >= 2.0 else 0)
    score += 2 if abs(r["kf_z"]) >= 1.0 else (1 if abs(r["kf_z"]) >= 0.5 else 0)
    if r["signal"] == "LONG"  and r["regime"] in ("Bull", "Sideways"): score += 2
    if r["signal"] == "SHORT" and r["regime"] in ("Bear", "Sideways"): score += 2
    return {6:"RẤT CAO 🔥",5:"RẤT CAO 🔥",4:"CAO ✅",3:"CAO ✅",
            2:"TRUNG BÌNH ⚠️"}.get(score, "THẤP 🔻")

def _ou_line(ou_z: float, signal: str) -> str:
    direction = "dưới" if ou_z < 0 else "trên"
    strength  = "cực mạnh" if abs(ou_z) >= 3 else ("mạnh" if abs(ou_z) >= 2 else "vừa")
    state     = "oversold" if signal == "LONG" else "overbought"
    return f"OU z-score = {ou_z:+.2f}σ → giá lệch {strength} {direction} cân bằng → {state}"

def _kf_line(kf_z: float, trend: str, signal: str) -> str:
    tr_em = TREND_EMOJI.get(trend, "→")
    state = "oversold" if signal == "LONG" else "overbought"
    sym   = "≪" if kf_z < 0 else "≫"
    if abs(kf_z) >= 0.5:
        return f"Kalman Filter z {sym} 0 → xác nhận {state} {tr_em} xu hướng {trend.lower()}"
    return f"Kalman Filter z = {kf_z:+.2f} → tín hiệu yếu, xu hướng {trend.lower()}"

def _hmm_line(r: dict) -> str:
    regime = r["regime"]
    signal = r["signal"]
    re_em  = REGIME_EMOJI.get(regime, "❓")
    bp, brp, sp = r["bull_p"], r["bear_p"], r["side_p"]
    if regime == "Sideways":
        return f"HMM regime: {re_em} Sideways (~{sp*100:.0f}%) → lý tưởng cho mean reversion"
    if regime == "Bull":
        note = "thuận chiều ✓" if signal == "LONG" else "ngược trend → giảm size, scalp only"
        return f"HMM regime: {re_em} Bull (~{bp*100:.0f}%) → {note}"
    if regime == "Bear":
        note = "thuận chiều ✓" if signal == "SHORT" else "ngược trend → stop chặt, size nhỏ"
        return f"HMM regime: {re_em} Bear (~{brp*100:.0f}%) → {note}"
    return "HMM regime: ❓ Không xác định → thận trọng"

def _adf_line(adf_p: float) -> str:
    if adf_p < 0.01:
        return f"ADF p = {adf_p} → stationary rõ ràng ✓ (mean reversion rất đáng tin)"
    if adf_p < 0.05:
        return f"ADF p = {adf_p} → stationary ✓ (mean reversion đáng tin)"
    return f"ADF p ≈ {adf_p} → có dấu hiệu stationarity, cần xác nhận thêm"

def _build_warnings(r: dict) -> list[str]:
    warns = []
    gv    = r["garch_vol"]
    if   gv >= 50: warns.append(f"⚠ Volatility rất cao (GARCH ~{gv:.0f}%/năm) → size nhỏ, không giữ qua đêm")
    elif gv >= 30: warns.append(f"ℹ Volatility cao (GARCH ~{gv:.0f}%/năm) → không nên giữ position lớn")
    if r["regime"] == "Bear"  and r["signal"] == "LONG":
        warns.append("⚠ Ngược xu hướng Bear → size ≤ 50% bình thường, stop chặt")
    if r["regime"] == "Bull"  and r["signal"] == "SHORT":
        warns.append("⚠ Ngược xu hướng Bull → chỉ scalp, không giữ qua đêm")
    if r["adf_p"] >= 0.05:
        warns.append("⚠ Mean reversion yếu → chờ thêm tín hiệu xác nhận")
    if r["mom20"]:
        try:
            mv = float(r["mom20"].replace("%", "").replace("+", ""))
            if r["signal"] == "LONG"  and mv < -10:
                warns.append(f"ℹ Momentum 20 ngày âm mạnh ({r['mom20']}) → có thể cần tích lũy thêm")
            if r["signal"] == "SHORT" and mv >  10:
                warns.append(f"ℹ Momentum 20 ngày dương mạnh ({r['mom20']}) → dòng tiền vẫn đang mua")
        except ValueError:
            pass
    return warns

def format_report(row: pd.Series) -> str:
    r = row.to_dict()
    if r["signal"] not in ("LONG", "SHORT"):
        return ""

    sig    = r["signal"]
    price  = r["price"]
    tick   = max(100, round(price * 0.002 / 100) * 100)

    # Entry zone
    if sig == "LONG":
        e_lo, e_hi   = int(price * 0.995 / tick) * tick, int(price * 1.003 / tick) * tick
        action_label = "🟢 LONG / MUA"
        entry_label  = "Entry (mua) "
    else:
        e_lo, e_hi   = int(price * 0.997 / tick) * tick, int(price * 1.005 / tick) * tick
        action_label = "🔴 SHORT / BÁN"
        entry_label  = "Entry (bán) "

    # Target range ±2%
    t_lo = int(r["target"] * 0.98 / tick) * tick
    t_hi = int(r["target"] * 1.02 / tick) * tick

    rr_lo = round(r["rr"] * 0.85, 1)
    rr_hi = round(r["rr"] * 1.10, 1)
    warns = _build_warnings(r)

    lines = [
        f"{'━'*54}",
        f"  Khuyến nghị giao dịch – {r['symbol']}  {_stars(r)}",
        f"  Tín hiệu   : {action_label}",
        f"  Độ tin cậy : {_confidence(r)}  |  📅 {today_str()}",
        f"{'─'*54}",
        "",
        f"  📖 Lý do tín hiệu",
        f"  {'·'*48}",
        f"  • {_ou_line(r['ou_z'], sig)}",
        f"  • {_kf_line(r['kf_z'], r['kf_trend'], sig)}",
        f"  • {_hmm_line(r)}",
        f"  • {_adf_line(r['adf_p'])}",
        "",
        f"  📌 Chiến lược giao dịch",
        f"  {'·'*48}",
        f"  {entry_label}        : ~{e_lo:,} – {e_hi:,} VND",
        f"  Target (mean-reversion): vùng {t_lo:,} – {t_hi:,} VND",
        f"                           (EQ = {r['price_eq']:,} | dự kiến ~{r['half_life']:.0f} phiên)",
        f"  Stop-loss              : ~{r['stop']:,} VND",
        "",
        f"  📊 Risk / Reward",
        f"  {'·'*48}",
        f"  Upside kỳ vọng : ~{r['upside']:.1f}%",
        f"  Risk           : ~{r['risk']:.1f}%",
        f"  R/R            : ~1 : {rr_lo} – {rr_hi}",
        f"  Thời gian giữ  : ~{r['half_life']:.0f} phiên giao dịch",
        f"  Mom(20d)       : {r['mom20'] or 'N/A'}",
    ]

    if warns:
        lines += ["", f"  ⚡ Lưu ý", f"  {'·'*48}"]
        lines += [f"  {w}" for w in warns]

    lines.append(f"{'━'*54}")
    return "\n".join(lines)


# ════════════════════════════════════════════════════════════════════════
# CONSOLE SUMMARY
# ════════════════════════════════════════════════════════════════════════

def print_summary(df: pd.DataFrame, loop_n: int, n_sym: int, n_cache: int) -> None:
    longs  = df[df["signal"] == "LONG"]
    shorts = df[df["signal"] == "SHORT"]
    flats  = df[df["signal"] == "FLAT"]

    print(f"\n{'═'*54}")
    print(f"  Scan #{loop_n}  |  {today_str()}")
    print(f"  Scanned: {n_sym}   Fitted: {n_cache}")
    print(f"  🟢 LONG: {len(longs)}   🔴 SHORT: {len(shorts)}   ⚪ FLAT: {len(flats)}")
    print(f"{'═'*54}")

    active = pd.concat([longs, shorts])
    if active.empty:
        print("  ⚪ Không có tín hiệu\n")
        return

    # Quick-glance table
    cols = ["symbol","signal","price","ou_z","kf_z","regime","kf_trend","target","rr"]
    print(active[cols].to_string(index=False))
    print()

    # Detailed reports
    for _, row in active.iterrows():
        rpt = format_report(row)
        if rpt:
            print(rpt + "\n")


# ════════════════════════════════════════════════════════════════════════
# MAIN
# ════════════════════════════════════════════════════════════════════════

def main() -> None:
    print(f"\n{'═'*54}")
    print(f"  VN Quant Scanner  —  OU + HMM + Kalman Filter")
    print(f"  Data  : {Config.HISTORY_START} → {Config.HISTORY_END}")
    print(f"  Top   : {Config.TOP_N} HOSE  |  Interval: {Config.SCAN_INTERVAL}s")
    print(f"{'═'*54}\n")

    # ── Khởi tạo ──
    symbols      = get_top_tickers()
    price_matrix = load_price_matrix(symbols)
    cache        = build_cache(price_matrix)

    if not cache:
        print("❌ 0 symbol qua filter. Thử tăng ADF_THRESHOLD hoặc MAX_HALF_LIFE.")
        return

    # ── Detect column names từ snapshot test ──
    test_snap = get_snapshot(symbols[:5])
    if test_snap is None:
        print("❌ Không lấy được snapshot")
        return

    try:
        sym_col   = find_col(test_snap, "symbol", "ticker", "code")
        price_col = find_col(test_snap, "match_price", "matchprice", "close", "price")
        print(f"[{now_str()}] ✓ col sym='{sym_col}'  price='{price_col}'\n")
    except KeyError as exc:
        print(f"❌ {exc}")
        return

    # ── Main loop ──
    all_snapshots: list[pd.DataFrame] = []
    refresh_at = datetime.datetime.now() + datetime.timedelta(minutes=Config.REFRESH_EVERY)
    loop_n     = 0

    try:
        while True:
            loop_n += 1
            snap = get_snapshot(symbols)

            if snap is None:
                print(f"[{now_str()}] ⚠ Snapshot lỗi – chờ {Config.SCAN_INTERVAL}s")
                time.sleep(Config.SCAN_INTERVAL)
                continue

            all_snapshots.append(snap)
            df_sig = compute_signals(snap, cache, price_matrix, sym_col, price_col)

            if df_sig.empty:
                print(f"[{now_str()}] #{loop_n} — không compute được signal")
            else:
                print_summary(df_sig, loop_n, len(symbols), len(cache))
                df_sig["timestamp"] = datetime.datetime.now()
                df_sig.to_csv("signals_latest.csv", index=False)
                print(f"  💾 signals_latest.csv")

            # Refresh cache định kỳ
            if datetime.datetime.now() >= refresh_at:
                print(f"\n[{now_str()}] 🔄 Refresh cache…")
                try:
                    symbols      = get_top_tickers()
                    price_matrix = load_price_matrix(symbols)
                    cache        = build_cache(price_matrix)
                    refresh_at   = datetime.datetime.now() + datetime.timedelta(minutes=Config.REFRESH_EVERY)
                except Exception as exc:
                    print(f"  ⚠ Refresh lỗi: {exc}")

            time.sleep(Config.SCAN_INTERVAL)

    except KeyboardInterrupt:
        print(f"\n[{now_str()}] Dừng. Lưu snapshot…")
        if all_snapshots:
            pd.concat(all_snapshots, ignore_index=True).to_csv("snapshots_full.csv", index=False)
            print("  💾 snapshots_full.csv")

    except Exception as exc:
        print(f"\n❌ Lỗi: {exc}")
        traceback.print_exc()


if __name__ == "__main__":
    main()

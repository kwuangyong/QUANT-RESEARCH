def get_top_tickers() -> list[str]:
    """Lấy top TOP_N mã HOSE theo accumulated volume trong ngày."""
    print(f"[{now_str()}] Lấy top {Config.TOP_N} tickers…")

    all_sym = safe_call(
        lambda: Listing(source="VCI").all_symbols().pipe(
            lambda d: d.rename(columns=str.lower)
        ),
        label="listing",
    )
    if all_sym is None:
        print(f"  ⚠ Dùng fallback {Config.TOP_N} tickers")
        return Config.FALLBACK_TICKERS[: Config.TOP_N]

    # Tìm cột symbol và cột exchange
    sym_col = next((c for c in all_sym.columns if "symbol" in c or "ticker" in c), all_sym.columns[0])
    hose: list[str] = []
    for col in ["comgroupcode", "exchange", "organtypecode", "type"]:
        if col in all_sym.columns:
            hose = all_sym[all_sym[col].str.upper() == "HOSE"][sym_col].tolist()
            if len(hose) > 10:
                break
    if len(hose) < 10:
        hose = all_sym[sym_col].tolist()

    # Lấy price board theo batch 20 để tính volume
    snaps: list[pd.DataFrame] = []
    for i in range(0, min(len(hose), 150), 20):
        batch = hose[i : i + 20]
        snap = safe_call(
            lambda b=batch: flatten_cols(Trading(source="VCI").price_board(b)),
            retries=2, delay=3, label=f"pb_{i//20}",
        )
        if snap is not None and len(snap) > 0:
            snaps.append(snap)
        time.sleep(1.5)

    if not snaps:
        return Config.FALLBACK_TICKERS[: Config.TOP_N]

    combined = pd.concat(snaps, ignore_index=True)
    try:
        vol_col = find_col(combined, "accumulated_volume", "totalvolume", "volume", "vol")
        sym_col = find_col(combined, "symbol", "ticker", "code")
    except KeyError:
        return Config.FALLBACK_TICKERS[: Config.TOP_N]

    combined[vol_col] = pd.to_numeric(combined[vol_col], errors="coerce")
    top = (
        combined.dropna(subset=[vol_col])
        .sort_values(vol_col, ascending=False)
        .head(Config.TOP_N)[sym_col]
        .tolist()
    )
    print(f"[{now_str()}] ✓ {len(top)} tickers: {top}")
    return top


def load_price_matrix(symbols: list[str]) -> pd.DataFrame:
    """Tải lịch sử giá đóng cửa, trả về DataFrame index=date, col=symbol."""
    print(f"[{now_str()}] Tải lịch sử {len(symbols)} symbols [{Config.HISTORY_START} → {Config.HISTORY_END}]…")
    dfs: list[pd.DataFrame] = []

    for idx, sym in enumerate(symbols, 1):
        def _fetch(s=sym):
            df = Quote(symbol=s, source="VCI").history(
                start=Config.HISTORY_START, end=Config.HISTORY_END, interval="1D"
            )
            df.columns = [c.lower() for c in df.columns]
            t_col = find_col(df, "time", "date", "datetime")
            c_col = find_col(df, "close")
            df[t_col] = pd.to_datetime(df[t_col])
            out = df.set_index(t_col)[[c_col]].rename(columns={c_col: s})
            out[s] = pd.to_numeric(out[s], errors="coerce")
            return out if len(out) >= Config.MIN_HISTORY else None

        result = safe_call(_fetch, retries=3, delay=3, label=sym)
        if result is not None:
            dfs.append(result)
        print(f"  [{idx:2d}/{len(symbols)}] {sym} {'✓' if result is not None else '✗'}")
        time.sleep(1.0)

    if not dfs:
        raise RuntimeError("Không tải được dữ liệu giá!")

    matrix = pd.concat(dfs, axis=1).sort_index().ffill().bfill()
    print(
        f"[{now_str()}] ✓ Matrix: {matrix.shape} "
        f"({matrix.index[0].date()} → {matrix.index[-1].date()})"
    )
    return matrix


def get_snapshot(symbols: list[str]) -> pd.DataFrame | None:
    """Lấy giá real-time từ price board."""
    snaps: list[pd.DataFrame] = []
    for i in range(0, len(symbols), 20):
        batch = symbols[i : i + 20]
        snap = safe_call(
            lambda b=batch: flatten_cols(Trading(source="VCI").price_board(b)),
            retries=2, delay=3, label="snapshot",
        )
        if snap is not None and len(snap) > 0:
            snaps.append(snap)
        time.sleep(0.8)

    if not snaps:
        return None
    df = pd.concat(snaps, ignore_index=True)
    df["timestamp"] = datetime.datetime.now()
    return df



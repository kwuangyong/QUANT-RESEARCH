# SIGNAL ENGINE
# ════════════════════════════════════════════════════════════════════════

def compute_signals(
    snap: pd.DataFrame,
    cache: dict,
    price_history: pd.DataFrame,
    sym_col: str,
    price_col: str,
) -> pd.DataFrame:
    rows: list[dict] = []

    for _, row in snap.iterrows():
        sym = row.get(sym_col)
        if sym not in cache:
            continue
        try:
            price = float(row[price_col])
            if not price or price <= 0 or np.isnan(price):
                continue
        except (TypeError, ValueError):
            continue

        m      = cache[sym]
        ou     = m["ou"]
        kf     = m["kf"]
        hmm    = m["hmm"]
        regime = hmm["regime"]

        ou_z = (np.log(price) - ou["mu"]) / max(ou["sigma_eq"], 1e-8)
        kf_z = (price - kf["kf_price"]) / max(abs(kf["kf_price"]) * 0.01, 1e-8)

        bear_dom = regime == "Bear"  and hmm["bear_prob"] > 0.7
        bull_dom = regime == "Bull"  and hmm["bull_prob"] > 0.7

        if   ou_z < -Config.OU_ENTRY_Z and kf_z < 0 and not bear_dom: signal = "LONG"
        elif ou_z >  Config.OU_ENTRY_Z and kf_z > 0 and not bull_dom: signal = "SHORT"
        else:                                                            signal = "FLAT"

        tick      = max(100, round(price * 0.002 / 100) * 100)
        price_eq  = m["price_eq"]
        target    = round(price_eq / tick) * tick
        stop_mult = (1 - Config.STOP_PCT) if signal == "LONG" else (1 + Config.STOP_PCT)
        stop      = round(price * stop_mult / tick) * tick
        if signal == "FLAT":
            target = stop = price

        upside = abs(target - price) / price * 100
        risk   = abs(stop - price) / price * 100
        rr     = round(upside / max(risk, 0.01), 2)

        mom20 = ""
        if sym in price_history.columns:
            hist = price_history[sym].dropna()
            if len(hist) >= 20:
                v     = (hist.iloc[-1] / hist.iloc[-20] - 1) * 100
                mom20 = f"{'+' if v >= 0 else ''}{v:.1f}%"

        rows.append({
            "symbol":    sym,
            "signal":    signal,
            "price":     int(price),
            "ou_z":      round(ou_z, 3),
            "kf_z":      round(kf_z, 3),
            "half_life": round(ou["half_life"], 1),
            "price_eq":  int(price_eq),
            "kf_price":  int(kf["kf_price"]),
            "kf_trend":  kf["trend"],
            "regime":    regime,
            "bull_p":    hmm["bull_prob"],
            "bear_p":    hmm["bear_prob"],
            "side_p":    hmm["side_prob"],
            "garch_vol": round(m["garch_vol"], 1) if not np.isnan(m["garch_vol"]) else 0.0,
            "target":    int(target),
            "stop":      int(stop),
            "upside":    round(upside, 2),
            "risk":      round(risk, 2),
            "rr":        rr,
            "mom20":     mom20,
            "adf_p":     m["adf_p"],
        })

    if not rows:
        return pd.DataFrame()
    return pd.DataFrame(rows).sort_values("ou_z").reset_index(drop=True)



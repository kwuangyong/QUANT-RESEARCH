def now_str()   -> str: return datetime.datetime.now().strftime("%H:%M:%S")
def today_str() -> str: return datetime.datetime.now().strftime("%d/%m/%Y %H:%M")

def flatten_cols(df: pd.DataFrame) -> pd.DataFrame:
    if isinstance(df.columns, pd.MultiIndex):
        df.columns = [
            "_".join(str(v) for v in col if v).strip("_").lower()
            for col in df.columns
        ]
    else:
        df.columns = [str(c).lower().strip() for c in df.columns]
    return df

def find_col(df: pd.DataFrame, *keywords: str) -> str:
    for kw in keywords:
        hits = [c for c in df.columns if kw.lower() in c.lower()]
        if hits:
            return hits[0]
    raise KeyError(f"Không tìm thấy cột {keywords}. Có: {list(df.columns)}")

def safe_call(fn, retries: int = 3, delay: int = 5, label: str = ""):
    """Gọi fn với retry tự động, trả None nếu thất bại."""
    for attempt in range(1, retries + 1):
        try:
            return fn()
        except Exception as exc:
            print(f"  ⚠ [{label}] lần {attempt}/{retries}: {type(exc).__name__} – chờ {delay}s…")
            time.sleep(delay)
    return None



# QUANTITATIVE MODELS
# ════════════════════════════════════════════════════════════════════════

def fit_ou(log_prices: np.ndarray) -> dict:
    """Fit Ornstein–Uhlenbeck via OLS, trả dict các tham số."""
    X   = add_constant(log_prices[:-1])
    res = OLS(log_prices[1:], X).fit()
    alpha, beta = res.params

    if not (0 < beta < 1):
        raise ValueError(f"β={beta:.4f} ∉ (0,1)")

    theta     = float(-np.log(beta))
    mu        = float(alpha / (1 - beta))
    resid_std = float(np.std(res.resid))
    sigma     = max(resid_std * np.sqrt(2 * theta / (1 - np.exp(-2 * theta))), 1e-8)
    half_life = float(np.log(2) / theta)
    sigma_eq  = sigma / np.sqrt(2 * theta)

    return {
        "theta": theta, "mu": mu, "sigma": sigma,
        "sigma_eq": sigma_eq, "half_life": half_life,
    }


def fit_hmm(log_returns: np.ndarray) -> dict:
    """Fit Gaussian HMM 3 trạng thái (Bear/Sideways/Bull)."""
    r = log_returns.reshape(-1, 1)
    if len(r) < 40:
        return {
            "regime": "UNKNOWN", "prob": 0.0,
            "bull_prob": 0.0, "bear_prob": 0.0, "side_prob": 0.0,
        }

    r_fit = r[-Config.HMM_WINDOW :]
    model = GaussianHMM(
        n_components=Config.HMM_N_STATES, covariance_type="full",
        n_iter=Config.HMM_ITER, random_state=42, tol=1e-4,
    )
    model.fit(r_fit)

    means      = model.means_.flatten()
    idx        = np.argsort(means)
    bear_s, side_s, bull_s = idx[0], idx[1], idx[2]
    labels     = {bear_s: "Bear", side_s: "Sideways", bull_s: "Bull"}

    probs         = model.predict_proba(r_fit)
    current_state = model.predict(r_fit)[-1]
    cp            = probs[-1]

    return {
        "regime":    labels[current_state],
        "prob":      round(float(cp[current_state]), 3),
        "bull_prob": round(float(cp[bull_s]), 3),
        "bear_prob": round(float(cp[bear_s]), 3),
        "side_prob": round(float(cp[side_s]), 3),
    }


def fit_kalman(prices: np.ndarray) -> dict:
    """Áp dụng Kalman Filter 1D, trả giá lọc + z-score + trend."""
    kf = KalmanFilter(
        transition_matrices=[[1]], observation_matrices=[[1]],
        initial_state_mean=[prices[0]], initial_state_covariance=[[1]],
        observation_covariance=[[Config.KF_OBS_NOISE]],
        transition_covariance=[[Config.KF_TRANS_NOISE]],
    )
    filtered, _ = kf.filter(prices.reshape(-1, 1))
    filtered     = filtered.flatten()

    residuals  = prices - filtered
    resid_std  = max(
        np.std(residuals[-60:]) if len(residuals) >= 60 else np.std(residuals), 1e-8
    )
    kf_z       = float((prices[-1] - filtered[-1]) / resid_std)
    win        = min(20, len(filtered))
    slope      = float(np.polyfit(np.arange(win), filtered[-win:], 1)[0])
    slope_pct  = slope / filtered[-win] * 100
    trend      = "Tăng" if slope_pct > 0.1 else ("Giảm" if slope_pct < -0.1 else "Ngang")

    return {
        "kf_price":  float(filtered[-1]),
        "kf_z":      round(kf_z, 3),
        "trend":     trend,
        "slope_pct": round(slope_pct, 4),
    }


def fit_garch(returns: pd.Series) -> float:
    """Dự báo volatility annualized (%) từ GARCH(1,1)."""
    r = returns.dropna() * 100
    if len(r) < 60:
        return np.nan
    try:
        gm = arch_model(r, vol="Garch", p=1, q=1, rescale=False)
        gf = gm.fit(disp="off", show_warning=False, options={"maxiter": 200})
        fc = gf.forecast(horizon=1, reindex=False)
        return float(np.sqrt(fc.variance.iloc[-1, 0]) / 100 * np.sqrt(252) * 100)
    except Exception:
        return np.nan


# ════════════════════════════════════════════════════════════════════════
# CACHE
# ════════════════════════════════════════════════════════════════════════

def build_cache(price_matrix: pd.DataFrame) -> dict:
    """Fit OU + HMM + Kalman + GARCH cho mỗi symbol, lưu vào cache."""
    print(f"[{now_str()}] Fitting models cho {len(price_matrix.columns)} symbols…")
    cache   = {}
    log_ret = np.log(price_matrix / price_matrix.shift(1)).dropna()

    for sym in price_matrix.columns:
        prices  = price_matrix[sym].dropna().values
        returns = log_ret[sym].dropna().values
        if len(prices) < Config.MIN_HISTORY:
            continue

        try:
            adf_p = adfuller(np.log(prices), autolag="AIC")[1]
            if adf_p > Config.ADF_THRESHOLD:
                continue

            ou = fit_ou(np.log(prices))
            if not (Config.MIN_HALF_LIFE <= ou["half_life"] <= Config.MAX_HALF_LIFE):
                continue

            hmm  = fit_hmm(returns)
            kf   = fit_kalman(prices)
            gvol = fit_garch(pd.Series(returns[-Config.GARCH_WINDOW :]))

            cache[sym] = {
                "ou": ou, "hmm": hmm, "kf": kf,
                "adf_p":     round(float(adf_p), 4),
                "price_eq":  float(np.exp(ou["mu"])),
                "garch_vol": gvol,
            }
            print(
                f"  {sym} ✓  hl={ou['half_life']:.0f}d  "
                f"regime={hmm['regime']}  trend={kf['trend']}",
                end="\r",
            )
        except Exception:
            continue

    print(f"\n[{now_str()}] ✓ {len(cache)}/{len(price_matrix.columns)} symbols fitted")
    return cache


